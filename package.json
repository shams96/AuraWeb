{
  "name": "isolavitale",
  "version": "1.0.0",
  "description": "Isola Vitale — Luxury Skincare Storefront",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "test": "npm run test --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web",
    "format": "prettier --write ."
  },
  "keywords": ["luxury", "cosmetics", "skincare", "ecommerce", "nextjs"],
  "author": "Isola Vitale",
  "license": "ISC",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.50.0",
    "@vitest/ui": "^3.0.0",
    "playwright": "^1.50.0",
    "prisma": "^6.3.0",
    "@prisma/client": "^6.3.0",
    "prettier": "^3.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
