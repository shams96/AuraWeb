# Database (leave unset to use the JSON file store in apps/web/data/)
DATABASE_URL="postgresql://username:password@localhost:5432/chiarel"

# NextAuth.js
NEXTAUTH_URL="http://localhost:5000"
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXT_PUBLIC_APP_URL="http://localhost:5000"

# Stripe (hosted checkout redirect — no publishable/client-side key needed)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend (Email)
RESEND_API_KEY="re_..."

# Google Tag Manager (optional — script only renders when this is set)
NEXT_PUBLIC_GTM_ID=""

# Internal/admin (optional — only set if you know you need them)
ADMIN_SEED_PASSWORD=""
INTERNAL_API_SECRET=""
